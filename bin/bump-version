#!/bin/bash
# Bumps the marketing version to today's date (YYYY.MM.DD) and resets the build number to 1.
# Usage: bin/bump-version

set -euo pipefail

cd "$(dirname "$0")/.."

NEW_VERSION=$(date +"%Y.%m.%d")
OLD_VERSION_PATTERN='[0-9]\{4\}\.[0-9]\{2\}\.[0-9]\{2\}'

PBXPROJ="File Cloud.xcodeproj/project.pbxproj"
PLIST="macOS/Info.plist"

# Update MARKETING_VERSION in pbxproj
sed -i '' "s/MARKETING_VERSION = ${OLD_VERSION_PATTERN};/MARKETING_VERSION = ${NEW_VERSION};/g" "$PBXPROJ"

# Reset CURRENT_PROJECT_VERSION to 1 in pbxproj
sed -i '' "s/CURRENT_PROJECT_VERSION = [0-9]*;/CURRENT_PROJECT_VERSION = 1;/g" "$PBXPROJ"

# Update Info.plist
/usr/libexec/PlistBuddy -c "Set :CFBundleShortVersionString ${NEW_VERSION}" "$PLIST"
/usr/libexec/PlistBuddy -c "Set :CFBundleVersion 1" "$PLIST"

echo "Bumped version to ${NEW_VERSION} (build 1)"
